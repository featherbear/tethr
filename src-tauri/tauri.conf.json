{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tethr",
  "version": "0.2.1",
  "identifier": "cc.featherbear.tethr",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "../src-tauri/binaries/js-runtime"
    ],
    "resources": {
      "../build": "build",
      "../server_modules/node_modules": "build/node_modules"
    }
  }
}
