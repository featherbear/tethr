{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tethr",
  "version": "0.2.1",
  "identifier": "cc.featherbear.tethr",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBundleCommand": "bash -c 'for f in src-tauri/target/{aarch64,x86_64,universal}-apple-darwin/release/tethr src-tauri/target/release/tethr; do [ -f \"$f\" ] && strip \"$f\"; done; true'",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../build": "build",
      "../server_modules/node_modules": "build/node_modules"
    }
  }
}
